# BidIt deployment configuration. Copy to .env and replace placeholders.
# Never commit real secrets, credentials, certificates, or private keys.

AWS_REGION=us-east-1
PROJECT_NAME=BidIt
API_STAGE_NAME=dev
ENVIRONMENT=dev

DYNAMODB_USERS_TABLE=Users
DYNAMODB_AUCTIONS_TABLE=Auctions
DYNAMODB_BIDS_TABLE=Bids
DYNAMODB_FAVORITES_TABLE=Favorites
DYNAMODB_NOTIFICATIONS_TABLE=Notifications

S3_BUCKET_NAME=your-bidit-images-bucket-name

LAMBDA_ROLE_NAME=BidItLambdaExecutionRole
STEP_FUNCTION_ROLE_NAME=BidItStepFunctionsRole
STEP_FUNCTION_NAME=WinnerMachine
STEP_FUNCTION_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:WinnerMachine

API_GATEWAY_NAME=BidItApi
VITE_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/dev

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

VITE_AGORA_APP_ID=your-agora-app-id
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERT=your-agora-app-certificate-placeholder
